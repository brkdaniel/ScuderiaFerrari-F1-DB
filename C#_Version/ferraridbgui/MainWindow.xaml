<Window x:Class="ScuderiaFerrariManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ferrari F1 Manager - Proiect BD" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Gestiune Date">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Row="0">
                        <TextBlock Text="Selectează Tabelul:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                        <ComboBox x:Name="CmbTables" Width="150" SelectionChanged="CmbTables_SelectionChanged">
                            <ComboBoxItem Content="Angajati"/>
                            <ComboBoxItem Content="Circuite"/>
                            <ComboBoxItem Content="Sponsori"/>
                            <ComboBoxItem Content="Furnizori"/>
                            <ComboBoxItem Content="Monoposturi"/>
                            <ComboBoxItem Content="Manageri"/>
                            <ComboBoxItem Content="Mecanici"/>
                            <ComboBoxItem Content="Piloti"/>
                            <ComboBoxItem Content="Piese"/>
                            <ComboBoxItem Content="Curse"/>
                            <ComboBoxItem Content="Contracte"/>
                            <ComboBoxItem Content="Oferte"/>
                            <ComboBoxItem Content="Rezultate"/>
                        </ComboBox>
                        <TextBlock Text="*Sortarea se face dând click pe capul de tabel" Margin="20,0,0,0" VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
                    </StackPanel>

                    <DataGrid x:Name="MainDataGrid" Grid.Row="1" Margin="5" AutoGenerateColumns="True" 
                              CanUserAddRows="True" CanUserDeleteRows="True" CanUserSortColumns="True"/>

                    <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="5">
                        <Button Content="Șterge Rând Selectat" Width="150" Margin="5" Background="#FF4C4C" Foreground="White" Click="BtnDelete_Click"/>
                        <Button Content="Salvează Modificările" Width="150" Margin="5" Background="#28A745" Foreground="White" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Rapoarte și Interogări Complexe">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical" Margin="5" Grid.Row="0">
                        <Button Content="Selecteaza Piloți, Rezultate și Monoposturi cu puncte > 10 și greutate &lt; 75kg" 
                                Margin="5" Padding="5" Click="BtnCerintaC_Click"/>
                        <Button Content="Valoarea totală a contractelor pe Manageri > 10.000.000" 
                                Margin="5" Padding="5" Click="BtnCerintaD_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ReportsDataGrid" Grid.Row="1" Margin="5" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <TabItem Header="Vizualizări (Views)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Row="0">
                        <Button Content="Afișează View LMD (Piese_Monopost)" Margin="5" Width="200" Click="BtnViewLMD_Click"/>
                        <Button Content="Afișează View Complex (Sponsori)" Margin="5" Width="200" Click="BtnViewComplex_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ViewsDataGrid" Grid.Row="1" Margin="5" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>